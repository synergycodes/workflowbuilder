  "private": true,
  "scripts": {
    "dev": "concurrently 'pnpm typecheck:watch' 'vite'",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch --pretty",
