    "@xyflow/react": "catalog:",
    "clsx": "^2.1.1",
    "immer": "^10.1.1",
    "react": "^19.1.0",
    "react-dom": "catalog:",
    "react-markdown": "^10.1.0",
    "recharts": "^3.9.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "@vitejs/plugin-react": "^4.3.4",
    "@workflowbuilder/sdk": "workspace:*",
    "vite": "^6.0.7",
