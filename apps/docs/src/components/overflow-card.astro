---
import overflowLogo from '../assets/overflow-logo.svg';

type Props = {
  /** Plugin-specific premium docs URL on overflow.dev */
  docsUrl: string;
};

const OVERFLOW_URL = 'https://www.overflow.dev';
const { docsUrl } = Astro.props;
---

<div class="overflow-card not-content" data-href={docsUrl} role="link" tabindex="0">
  <div class="card-body">
    <a href={OVERFLOW_URL} class="logo-link" target="_blank" rel="noopener noreferrer">
      <img src={overflowLogo.src} alt="Overflow" class="logo" width="139" height="26" />
    </a>
    <p class="description">
      This plugin is powered by Overflow, a React Flow UI library for building visual workflows, automations, and tools
      with production-grade components.
    </p>
    <span class="docs-link">
      See the detailed docs
      <svg
        class="arrow-icon"
        viewBox="0 0 16 16"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M3 8h10M9 4l4 4-4 4"></path>
      </svg>
    </span>
  </div>
</div>

<script>
  function setupOverflowCards() {
    for (const card of document.querySelectorAll<HTMLElement>('.overflow-card[data-href]')) {
      card.addEventListener('click', (event) => {
        if ((event.target as HTMLElement).closest('.logo-link')) return;
        window.open(card.dataset.href, '_blank');
      });
      card.addEventListener('keydown', (event) => {
        if (event.key === 'Enter') window.open(card.dataset.href, '_blank');
      });
    }
  }
  document.addEventListener('astro:page-load', setupOverflowCards);
</script>

<style>
  .overflow-card {
    display: block;
    margin-block: 1.5rem;
    border-radius: 0.75rem;
    border: 1px solid var(--sl-color-gray-5);
    background-color: var(--sl-color-bg);
    overflow: hidden;
    transition: border-color 0.2s;
    cursor: pointer;
  }

  .overflow-card:hover {
    border-color: var(--sl-color-gray-4);
  }

  .card-body {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding-block: 1.25rem;
    padding-inline: 1.5rem;
  }

  .logo-link {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
  }

  .logo {
    block-size: 2rem;
    inline-size: auto;
    display: block;
  }

  .description {
    margin: 0;
    font-size: var(--sl-text-sm);
    line-height: 1.6;
    color: var(--sl-color-gray-2);
  }

  .docs-link {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    gap: 0.35rem;
    font-size: var(--sl-text-sm);
    font-weight: 600;
    color: var(--sl-color-accent);
  }

  .overflow-card:hover .docs-link {
    text-decoration: underline;
  }

  .arrow-icon {
    inline-size: 0.875rem;
    block-size: 0.875rem;
    flex-shrink: 0;
  }
</style>
