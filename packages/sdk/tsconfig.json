{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "verbatimModuleSyntax": true,
    "baseUrl": ".",
    "lib": ["DOM", "ES2022"],
    "paths": {
      "@workflowbuilder/sdk": ["./src/index.ts"],
      "@/*": ["./src/*"]
    },
    "types": ["node", "vite/client", "vite-plugin-svgr/client", "vitest/globals"]
  },
  "exclude": ["node_modules", "dist", "src/__shims__"]
}
