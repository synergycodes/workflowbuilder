# hidden directories
.git
.vscode
.idea
.claude

# external dependencies
node_modules
**/node_modules

# docker files
docker-compose*.yml
**/Dockerfile*

# build artifacts
dist/
**/dist
coverage/
**/coverage

# not needed files
README.md
tools/
!tools/deployment/nginx
.gitignore

# env files hold secrets (e.g. OPENROUTER_API_KEY) and must never enter the
# build context — runtime config is injected via docker-compose `environment`
**/.env
**/.env.*
!**/.env.example
